# =============================================================================
# Polymarket Edge Scanner — example environment file
# Copy to `.env` and adjust. NEVER commit your real .env or any secrets.
# =============================================================================

# ---- Safety switches -------------------------------------------------------
# Paper trading is the ONLY supported mode in this MVP. Live trading is NOT
# implemented. This flag exists so the wiring is explicit and auditable.
PAPER_TRADING_ENABLED=true
# Live trading is intentionally hard-disabled. Setting this to true does NOT
# enable real orders in the MVP — it only documents intent. Implementing live
# execution is left as an explicit, manually-approved future step.
LIVE_TRADING_ENABLED=false

# ---- Polymarket public API endpoints (no key required for read access) -----
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
# Be polite to the public API. Minimum seconds between HTTP requests.
HTTP_MIN_INTERVAL_SECONDS=0.25
HTTP_TIMEOUT_SECONDS=20
HTTP_CACHE_TTL_SECONDS=30

# ---- Scanner / scheduler ---------------------------------------------------
SCAN_INTERVAL_SECONDS=300
SCAN_ON_STARTUP=true
MARKET_FETCH_LIMIT=200

# ---- Bankroll & risk (paper) ----------------------------------------------
PAPER_BANKROLL=1000
MAX_POSITION_PCT=0.01        # 1% of bankroll max per trade
MAX_MARKET_EXPOSURE_PCT=0.05 # 5% of bankroll per market
MAX_CATEGORY_EXPOSURE_PCT=0.15 # 15% of bankroll per category
ALLOW_AVERAGING=false        # allow multiple trades on same market/outcome

# ---- Quality filters -------------------------------------------------------
MIN_LIQUIDITY=5000
MIN_VOLUME_24H=500
MAX_SPREAD=0.05
MAX_DAYS_TO_RESOLUTION=400
STRONG_LIQUIDITY_OVERRIDE=50000  # allow far-out markets if liquidity above this
ALLOW_EXTREME_PRICES=false       # include markets priced near 0 or 1
EXTREME_PRICE_BAND=0.05          # "near 0/1" = price < band or > 1-band

# ---- Edge / fee model ------------------------------------------------------
ESTIMATED_FEE=0.0            # Polymarket taker fee (configurable; 0 by default)
SAFETY_MARGIN=0.015
MIN_EDGE_TO_TRADE=0.025

# ---- Optional external signals ---------------------------------------------
# CSV with columns: market_slug,outcome,external_probability,source,timestamp
EXTERNAL_SIGNALS_CSV=data/external_signals.csv

# ---- Optional LLM / news (NOT used for trade decisions) --------------------
# Reserved for future bounded news-adjustment + explanations only.
# ANTHROPIC_API_KEY=
NEWS_SIGNAL_ENABLED=false
